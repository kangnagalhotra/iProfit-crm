// iProfit CRM — Prisma schema (MySQL)
// Covers: Users, Accounts (customers), Leads, Activities, Tasks, Opportunities,
//         Notifications, plus the join/audit tables the modules need.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  SALES_MANAGER
  SALES_REP
}

enum LeadSource {
  IMPORT // system-set only (CSV import) — not shown in the manual-entry dropdown
  OUTREACH
  EMAIL
  CAMPAIGN
  REFERRAL
  WEBSITE
  SOCIAL_MEDIA
  EVENT
  PARTNER
  OTHER
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  FIELD_UPDATE
}

enum TaskType {
  TODO
  CALL
  EMAIL
  FOLLOW_UP
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DealType {
  NEW_BUSINESS
  EXISTING_BUSINESS
  RENEWAL
}

enum NotificationType {
  RECORD_ASSIGNED
  TASK_DUE
  STAGE_CHANGED
  MENTION
  LEAD_INACTIVE
}

// ---------------------------------------------------------------------------
// CORE MODELS
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  fullName     String   @db.VarChar(200)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         Role     @default(SALES_REP)
  isActive     Boolean  @default(true)
  // soft lockout tracking for the 5-attempt / 15-min rule
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  lastActiveAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // round-robin assignment helper: whether this rep is in the rotation
  inAssignmentPool Boolean @default(true)

  ownedLeads         Lead[]          @relation("LeadOwner")
  ownedAccounts      Account[]       @relation("AccountOwner")
  ownedOpportunities Opportunity[]   @relation("OppOwner")
  assignedTasks      Task[]          @relation("TaskAssignee")
  createdActivities  Activity[]      @relation("ActivityCreator")
  notifications      Notification[]

  @@index([role])
  @@index([email])
}

model AccountStage {
  id        String    @id @default(uuid())
  name      String    @db.VarChar(100)
  order     Int
  color     String    @db.VarChar(20)
  isDefault Boolean   @default(false)
  accounts  Account[]
  createdAt DateTime  @default(now())

  @@index([order])
}

model Account {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(200)
  domain        String?  @db.VarChar(255)
  industry      String?  @db.VarChar(120)
  sizeBucket    String?  @db.VarChar(40)   // "1-10", "11-50", ...
  annualRevenue Decimal? @db.Decimal(15, 2)
  city          String?  @db.VarChar(120)
  state         String?  @db.VarChar(120)
  country       String?  @db.VarChar(120)
  companyType   String?  @db.VarChar(80)
  email         String?  @db.VarChar(255)
  phone         String?  @db.VarChar(40)
  address       String?  @db.VarChar(255)
  description   String?  @db.Text
  stageId       String
  stage         AccountStage @relation(fields: [stageId], references: [id])
  ownerId       String?
  owner         User?    @relation("AccountOwner", fields: [ownerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         Lead[]
  opportunities Opportunity[]
  activities    Activity[]
  tasks         Task[]

  @@index([domain])
  @@index([ownerId])
  @@index([stageId])
}

model LeadStage {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  order     Int
  color     String   @db.VarChar(20)
  isWon     Boolean  @default(false)
  isLost    Boolean  @default(false)
  isDefault Boolean  @default(false)
  leads     Lead[]
  createdAt DateTime @default(now())

  @@index([order])
}

model Lead {
  id         String     @id @default(uuid())
  leadName   String?    @db.VarChar(200)
  firstName  String?    @db.VarChar(100)
  lastName   String?    @db.VarChar(100)
  email      String?    @db.VarChar(255)
  phone      String?    @db.VarChar(40)
  jobTitle   String?    @db.VarChar(150)
  city       String?    @db.VarChar(120)
  value      Decimal?   @db.Decimal(15, 2)
  notes      String?    @db.Text
  stageId    String
  stage      LeadStage  @relation(fields: [stageId], references: [id])
  source     LeadSource @default(OTHER)
  score      Int        @default(0)

  ownerId    String?
  owner      User?      @relation("LeadOwner", fields: [ownerId], references: [id])
  accountId  String?
  account    Account?   @relation(fields: [accountId], references: [id])

  // for inactivity alerts
  lastActivityAt DateTime?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  activities    Activity[]
  tasks         Task[]
  opportunities Opportunity[]

  @@unique([email])
  @@index([ownerId])
  @@index([stageId])
  @@index([lastActivityAt])
}

model Pipeline {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(120)
  isDefault Boolean  @default(false)
  stages    Stage[]
  opportunities Opportunity[]
  createdAt DateTime @default(now())
}

model Stage {
  id          String  @id @default(uuid())
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id])
  name        String   @db.VarChar(100)
  order       Int
  color       String   @db.VarChar(20)
  isDefault   Boolean  @default(false)
  winProbability Int   @default(0) // 0-100
  isClosedWon  Boolean @default(false)
  isClosedLost Boolean @default(false)
  opportunities Opportunity[]

  @@index([pipelineId])
}

model Opportunity {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(200)
  amount      Decimal? @db.Decimal(15, 2)
  closeDate   DateTime?
  dealType    DealType @default(NEW_BUSINESS)
  description String?  @db.Text
  source      String?  @db.VarChar(80)

  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id])
  stageId     String
  stage       Stage    @relation(fields: [stageId], references: [id])

  ownerId     String
  owner       User     @relation("OppOwner", fields: [ownerId], references: [id])
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])

  lossReason  String?  @db.VarChar(255)
  closedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities  Activity[]
  tasks       Task[]
  stageHistory StageHistory[]

  @@index([ownerId])
  @@index([stageId])
  @@index([pipelineId])
}

model StageHistory {
  id            String   @id @default(uuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  fromStageId   String?
  toStageId     String
  changedById   String
  changedAt     DateTime @default(now())

  @@index([opportunityId])
}

model Activity {
  id          String       @id @default(uuid())
  type        ActivityType
  body        String       @db.Text
  // call/meeting extras stored as JSON to stay schema-light for v1
  meta        Json?
  occurredAt  DateTime     @default(now())

  creatorId   String
  creator     User         @relation("ActivityCreator", fields: [creatorId], references: [id])

  // polymorphic-ish associations (nullable FKs; an activity can touch several)
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id])
  accountId     String?
  account       Account?     @relation(fields: [accountId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  taskId        String?
  task          Task?        @relation(fields: [taskId], references: [id])

  createdAt   DateTime     @default(now())

  @@index([leadId])
  @@index([opportunityId])
  @@index([taskId])
  @@index([creatorId])
}

model Task {
  id          String       @id @default(uuid())
  title       String       @db.VarChar(250)
  type        TaskType     @default(TODO)
  status      TaskStatus   @default(NOT_STARTED)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime
  notes       String?      @db.Text
  reminderAt  DateTime?

  assigneeId  String
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id])

  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id])
  accountId     String?
  account       Account?     @relation(fields: [accountId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  activities  Activity[]

  @@index([assigneeId])
  @@index([dueAt])
  @@index([status])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  message   String           @db.VarChar(500)
  linkUrl   String?          @db.VarChar(500)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}
